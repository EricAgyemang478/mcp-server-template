{
  "name": "mcp-server-template",
  "version": "1.0.0",
  "description": "A production-ready Model Context Protocol (MCP) server template — typed tools, tests, Docker, and CI.",
  "type": "module",
  "bin": {
    "mcp-server-template": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/text.test.ts test/notes.test.ts test/server.test.ts",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "tools",
    "template"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
